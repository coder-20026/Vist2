<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Needed so a fresh fix can be obtained when the app is triggered in the background -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Notification on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Light vibration on COPY -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Re-arm the manifest receiver after reboot (receiver itself survives, this is just hygiene) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GpsCoordinateCopy">

        <!-- Minimal status screen -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Invisible activity that performs the clipboard copy with a focused context -->
        <activity
            android:name=".CopyActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@style/Theme.Transparent" />

        <!-- Listens for the system Location/GPS ON-OFF event. -->
        <!-- android.location.PROVIDERS_CHANGED is EXEMPT from the implicit-broadcast -->
        <!-- restrictions, so a manifest-declared receiver works even while the app is dormant. -->
        <!-- The fresh fix is fetched directly inside the receiver via goAsync() - no -->
        <!-- foreground service is started from the background (which Android 12+ blocks). -->
        <receiver
            android:name=".ProvidersChangedReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.location.PROVIDERS_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- Handles DISMISS and the 10-minute AUTO_COPY alarm -->
        <receiver
            android:name=".ActionReceiver"
            android:exported="false" />

    </application>
</manifest>
